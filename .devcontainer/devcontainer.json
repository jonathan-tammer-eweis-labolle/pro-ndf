{
    "name": "pro-ndf",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "8g"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.formatting.provider": "black",
                "editor.formatOnSave": true
            }
        }
    },
    "postCreateCommand": "pip install --upgrade pip && echo 'Environment ready!'",
    "remoteUser": "root"
}
